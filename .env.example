COMPOSE_PROJECT_NAME=portal-corporativo
ASPNETCORE_ENVIRONMENT=Development

# Local development placeholders only. Replace every CHANGE_ME value in .env.
SQLSERVER_SA_PASSWORD=CHANGE_ME_Strong_Local_Password_123!
SQLSERVER_PORT=1433
REDIS_PASSWORD=CHANGE_ME_Redis_Local_Password
REDIS_PORT=6379

JWT_ISSUER=portal-corporativo
JWT_AUDIENCE=portal-corporativo-clients
JWT_SECRET=CHANGE_ME_Use_At_Least_32_Random_Characters

MINIO_ROOT_USER=CHANGE_ME_Minio_User
MINIO_ROOT_PASSWORD=CHANGE_ME_Minio_Local_Password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

API_GATEWAY_PORT=8080
SEQ_PORT=5341
KAFKA_ENABLED=false
MESSAGE_TRANSPORT=SqlOutbox
NOTIFICATION_POLL_SECONDS=5
NOTIFICATION_MAX_ATTEMPTS=5
