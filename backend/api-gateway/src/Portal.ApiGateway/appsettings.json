{
  "Jwt": {
    "Issuer": "portal-corporativo",
    "Audience": "portal-corporativo-clients"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp.ReverseProxy": "Information"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "security": {
        "ClusterId": "security",
        "Match": { "Path": "/api/security/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "configuration": {
        "ClusterId": "configuration",
        "Match": { "Path": "/api/configuration/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "menu": {
        "ClusterId": "menu",
        "Match": { "Path": "/api/menu/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "audit": {
        "ClusterId": "audit",
        "Match": { "Path": "/api/audit/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notification": {
        "ClusterId": "notification",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "catalog": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/catalogs/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Transforms": [{ "PathRemovePrefix": "/api/catalogs" }]
      },
      "content": {
        "ClusterId": "content",
        "Match": { "Path": "/api/content/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Transforms": [{ "PathRemovePrefix": "/api/content" }]
      },
      "integration": {
        "ClusterId": "integration",
        "Match": { "Path": "/api/integration/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Transforms": [{ "PathRemovePrefix": "/api/integration" }]
      },
      "reporting": {
        "ClusterId": "reporting",
        "Match": { "Path": "/api/reporting/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Transforms": [{ "PathRemovePrefix": "/api/reporting" }]
      }
    },
    "Clusters": {
      "security": { "Destinations": { "primary": { "Address": "http://security-api:8080/" } } },
      "configuration": { "Destinations": { "primary": { "Address": "http://configuration-api:8080/" } } },
      "menu": { "Destinations": { "primary": { "Address": "http://menu-api:8080/" } } },
      "audit": { "Destinations": { "primary": { "Address": "http://audit-api:8080/" } } },
      "notification": { "Destinations": { "primary": { "Address": "http://notification-api:8080/" } } },
      "catalog": { "Destinations": { "primary": { "Address": "http://catalog-api:8080/" } } },
      "content": { "Destinations": { "primary": { "Address": "http://content-api:8080/" } } },
      "integration": { "Destinations": { "primary": { "Address": "http://integration-api:8080/" } } },
      "reporting": { "Destinations": { "primary": { "Address": "http://reporting-api:8080/" } } }
    }
  },
  "AllowedHosts": "*"
}
